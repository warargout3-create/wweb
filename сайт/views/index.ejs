<%- include('partials/header') %>

<!-- Hero Section -->
<section class="hero-section" id="hero">
    <div class="hero-bg-overlay"></div>
    <div class="hero-content">
        <div class="hero-text" data-aos="fade-up">
            <div class="hero-badge">
                <i class="fas fa-chalkboard-teacher"></i>
                <span>Студент ВМК МГУ • Преподаватель математики и физики</span>
            </div>
            <h1 class="hero-title">Образовательная платформа</h1>
            <p class="hero-subtitle">Индивидуальные занятия по математике и физике с действующим студентом <strong>ВМК МГУ</strong>. Подготовка к <strong>ЕГЭ, ОГЭ, ДВИ МГУ</strong> и поступлению в ведущие вузы страны. Авторская методика, проверенная на 50+ учениках.</p>
            <div class="hero-cta">
                <a href="#about" class="btn btn-primary"><i class="fas fa-user"></i> О преподавателе</a>
                <a href="/materials/math" class="btn btn-outline"><i class="fas fa-book"></i> Материалы</a>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
